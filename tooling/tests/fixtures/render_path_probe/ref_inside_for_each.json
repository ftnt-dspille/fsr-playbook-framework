{
  "scenario": "ref_inside_for_each",
  "playbook_name": "rp_ref_loop_parent",
  "description": "for_each over ref calls; capture per-iteration outputs",
  "yaml": "collection: \"FSRPB Render Path Probe\"\ndescription: \"render-path probe collection\"\nplaybooks:\n  - name: \"rp_ref_loop_child\"\n    description: \"child for rp_ref_loop_parent\"\n    is_active: true\n    parameters: ['n']\n    steps:\n      - name: \"ChildStart\"\n        type: start\n        next: \"Compute\"\n      - name: \"Compute\"\n        type: set_variable\n        vars:\n          squared: \"{{ (vars.input.params.n | int) ** 2 }}\"\n  - name: \"rp_ref_loop_parent\"\n    description: \"parent calls child once per item\"\n    is_active: true\n    steps:\n      - name: \"Trigger\"\n        type: start\n        next: \"Loop\"\n      - name: \"Loop\"\n        type: workflow_reference\n        for_each:\n          item: \"{{ [1, 2, 3] }}\"\n          parallel: false\n        arguments:\n          target: rp_ref_loop_child\n          arguments:\n            n: \"{{ vars.item }}\"\n          apply_async: false\n          pass_parent_env: false\n          pass_input_record: false\n        next: \"Capture\"\n      - name: \"Capture\"\n        type: set_variable\n        vars:\n          loop_seen: \"{{ vars.steps.Loop }}\"\n          loop_count: \"{{ vars.steps.Loop | length }}\"\n",
