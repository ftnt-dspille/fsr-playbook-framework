# Copy to .env (gitignored) and fill in. fsrpb probes refuse to do live work
# without FSR_BASE_URL + one auth block.

# --- Required ---
FSR_BASE_URL=https://fsr-1.your.lab

# --- Auth: choose ONE block ---

# Option A: API key (preferred)
FSR_API_KEY=

# Option B: username + password (pyfsr exchanges for JWT)
# FSR_USERNAME=
# FSR_PASSWORD=

# --- Optional ---
FSR_VERIFY_SSL=true
FSR_PORT=
FSR_TIMEOUT=30

# --- Phase-5 e2e guardrails ---
# Free-form label written into _probe_runs.notes for traceability.
FSR_INSTANCE_LABEL=dev
# Live upload/execute/cleanup probes refuse to run unless this is true.
# NEVER set true on prod.
FSR_ALLOW_E2E=false

# --- AI chat / eval loop (make chat-drive, chat-calibrate, evals) ---
# Required for ANY live agent run or eval. Get one from the Anthropic console.
ANTHROPIC_API_KEY=
# Override the eval model (default: a current Claude). Leave unset for the default.
# EVAL_ANTHROPIC_MODEL=
# Build-fidelity grounding gate (default 1.0 — every built op must be investigated).
# EVAL_BUILD_FIDELITY_GROUNDING_GATE=1.0

# --- Internal OpenAI-compatible gateway (default provider) ---
# Point the fsr_core factory at any OpenAI-compatible endpoint. With
# STUDIO_LLM_PROVIDER=openai, web-backend / local runs default to this gateway;
# base_url + model are read from OPENAI_ENDPOINT / OPENAI_MODEL below.
STUDIO_LLM_PROVIDER=openai
OPENAI_ENDPOINT=https://cse-devops-ai-gw.fortilab.fortinet.com/v1
OPENAI_MODEL=gb200/gpt-oss-120b
OPENAI_API_KEY=

# --- First-run setup (scripts/bootstrap.sh) ---
# Reference DB: a clone has none (gitignored, ~63M). EITHER point bootstrap at a
# copy to hand over, OR leave unset and rebuild from YOUR box with `fsrpb refresh`.
# FSR_DB_SRC=/path/to/fsr_reference.db
# pyfsr is a required sibling clone; bootstrap clones it here if ../pyfsr is missing.
# PYFSR_REPO=git@github.com:ftnt-dspille/pyfsr.git
# Override the reference DB path the tooling opens (default: store/fsr_reference.db).
# FSRPB_DB=

# --- Connector deploy + live-drive (sibling connector repo reads THIS .env) ---
# deploy.sh sources this file, so the connector vars live here too.
# Named config to create/refresh on the box.
# FSR_BUILDER_CONFIG_NAME=fsrpb-live
# Agent model the connector runs on. Testing pins Haiku (cheap); override to raise it.
# FSR_BUILDER_MODEL=claude-haiku-4-5-20251001
# The connector also accepts FSR_VERIFY_TLS as a mirror of FSR_VERIFY_SSL.
