    {
      "model": "agentic_anthropic",
      "task": "jinja_chain_json_payload",
      "yaml": "collection: My Collection\nplaybooks:\n  - name: Post Artifact Count and Names to Webhook\n    description: >\n      Builds a JSON payload containing the count and names of artifacts\n      related to the triggering alert, then POSTs it to a webhook via\n      cyops_utilities api_call.\n    is_active: true\n    steps:\n\n      - type: start\n        name: Start\n        arguments:\n          module: alerts\n          button_label: Post Artifacts to Webhook\n          run_mode: per_record\n        next: Build Payload\n\n      - type: set_variable\n        name: Build Payload\n        vars:\n          artifact_count: \"{{ vars.input.records[0].artifactsRelatedToAlerts | length }}\"\n          artifact_names: \"{{ vars.input.records[0].artifactsRelatedToAlerts | map(attribute='value') | list }}\"\n          webhook_body: \"{{ {'count': vars.artifact_count, 'names': vars.artifact_names} | to_json }}\"\n        next: Post to Webhook\n\n      - type: connector\n        name: Post to Webhook\n        arguments:\n          connector: cyops_utilities\n          operation: api_call\n          config: ''\n          params:\n            url: 'https://your-webhook-endpoint.example.com/hook'\n            method: POST\n            body: '{{ vars.webhook_body }}'\n            headers: '{\"Content-Type\": \"application/json\"}'\n            verify: true\n        next: End\n\n      - type: end\n        name: End",
