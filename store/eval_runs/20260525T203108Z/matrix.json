      "yaml": "collection: Threat Intelligence\nplaybooks:\n  - name: VT IP Lookup on Alert Creation\n    description: On alert creation, extracts the first source IP and submits it to VirusTotal for reputation scoring.\n    is_active: true\n    steps:\n      - type: start_on_create\n        name: On Alert Created\n        arguments:\n          module: alerts\n        next: Extract Target IP\n\n      - type: set_variable\n        name: Extract Target IP\n        vars:\n          target_ip: \"{{ vars.input.records[0].sourceIps[0] }}\"\n        next: Query VirusTotal\n\n      - type: connector\n        name: Query VirusTotal\n        arguments:\n          connector: virustotal\n          operation: query_ip\n          config: ''\n          params:\n            ip: \"{{ vars.target_ip }}\"\n        next: End\n\n      - type: end\n        name: End",
