#!/usr/bin/env bash
# pre-push: keep the PUBLIC GitHub mirror in sync automatically.
#
# When you push `main` to the internal GitLab `origin`, this also rebuilds the
# sanitized snapshot and force-pushes it to the public GitHub mirror via
# scripts/publish_public.sh — so the public copy can never silently drift.
#
# Notes:
#   - Only fires when refs/heads/main is among the pushed refs AND the target
#     remote is the internal GitLab host (not the github mirror, not forks).
#   - publish_public.sh is fully self-contained (builds in a mktemp dir, pushes
#     from there); it never touches this repo's .git, so running it here is safe.
#   - The publish step is NON-BLOCKING for your GitLab push: if it fails (e.g.
#     the sanitation gate catches a leak, or GitHub is unreachable) you get a
#     LOUD warning but the internal push still succeeds. Re-run `make
#     publish-public` once resolved.
#   - Bypass entirely with:  SKIP_PUBLIC_MIRROR=1 git push
#
# Installed copy lives at .git/hooks/pre-push. Source of truth is
# scripts/git-hooks/pre-push — reinstall after a fresh clone with `make hooks`.

remote_name="$1"
remote_url="$2"

[[ "${SKIP_PUBLIC_MIRROR:-0}" == "1" ]] && exit 0

# Only mirror when pushing to the internal GitLab host.
case "$remote_url" in
    *svl-devops-gitlab01.fortilab.fortinet.com*) ;;
    *) exit 0 ;;
esac

# Is main among the refs being pushed? (stdin: <localref> <localsha> <remoteref> <remotesha>)
pushing_main=0
while read -r local_ref local_sha remote_ref remote_sha; do
    [[ "$local_ref" == "refs/heads/main" || "$remote_ref" == "refs/heads/main" ]] && pushing_main=1
done
[[ "$pushing_main" == "1" ]] || exit 0

repo_root="$(git rev-parse --show-toplevel)"

echo ">> [pre-push] main -> GitLab; syncing public GitHub mirror..."
if "$repo_root/scripts/publish_public.sh"; then
    echo ">> [pre-push] public mirror synced."
else
    rc=$?
    echo "" >&2
    echo "############################################################" >&2
    echo "## WARNING: public mirror sync FAILED (exit $rc)" >&2
    echo "## Your GitLab push will STILL proceed." >&2
    echo "## The public GitHub mirror is now BEHIND. Re-run:" >&2
    echo "##     make publish-public" >&2
    echo "## once the cause is fixed (leak in sanitation gate? gh auth?)." >&2
    echo "############################################################" >&2
    echo "" >&2
fi

# Never block the internal push on mirror outcome.
exit 0
